{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "strict": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "baseUrl": ".",
    "types": ["node", "cypress"]
  },
  "include": [
    "playwright/**/*.ts",
    "cypress/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
