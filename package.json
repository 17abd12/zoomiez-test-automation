{
  "name": "zoomiez-test-documentation",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test:playwright": "playwright test -c playwright/playwright.config.ts",
    "test:playwright:ui": "playwright test --ui -c playwright/playwright.config.ts",
    "test:playwright:report": "playwright show-report docs/playwright",
    "test:cypress:open": "node scripts/run-cypress.js open",
    "test:cypress:run": "node scripts/run-cypress.js run",
    "test:k6": "k6 run k6/scenarios/login-load.js && k6 run k6/scenarios/papers-load.js && k6 run k6/scenarios/dashboard-load.js",
    "test:k6:login": "k6 run k6/scenarios/login-load.js",
    "test:k6:papers": "k6 run k6/scenarios/papers-load.js",
    "test:k6:dashboard": "k6 run k6/scenarios/dashboard-load.js",
    "test:k6:screenshots": "node -e \"require('fs').mkdirSync('docs/k6/screenshots', {recursive: true})\" && k6 run k6/screenshots.js",
    "test:newman": "node newman/mint-tokens.js && newman run newman/zoomiez-collection.json -e newman/environments/local.json --reporters cli,htmlextra --reporter-htmlextra-export docs/newman/index.html",
    "test:backend": "cd backend-tests && pytest . -v --html=../docs/pytest/index.html --self-contained-html",
    "test:allure": "allure generate allure-results -o docs/allure --clean",
    "test:allure:open": "allure open docs/allure",
    "typecheck": "tsc --noEmit",
    "test:all": "npm run test:playwright && npm run test:cypress:run && npm run test:newman && npm run test:k6 && npm run test:backend && npm run test:allure"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "allure-commandline": "^2.30.0",
    "allure-cypress": "^3.0.0",
    "allure-playwright": "^3.0.0",
    "cross-env": "^10.1.0",
    "cypress": "^13.0.0",
    "cypress-mochawesome-reporter": "^3.8.4",
    "msw": "^2.4.0",
    "newman": "^6.1.0",
    "newman-reporter-allure": "^1.0.0",
    "newman-reporter-htmlextra": "^1.23.1",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "jsonwebtoken": "^9.0.0"
  }
}
