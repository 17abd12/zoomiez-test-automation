          "event": [{ "listen": "test", "script": { "exec": ["pm.test('status 200 or 201', () => { pm.expect([200,201]).to.include(pm.response.code); });"] } }]
        },
        {
          "name": "UC-TC-02 Get Invite History",
          "request": { "method": "GET", "url": "{{base_url}}/api/teacher/students/invites", "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token_teacher}}" }] },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('status 200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "UC-TC-03 Teacher Statistics",
          "request": { "method": "GET", "url": "{{base_url}}/api/teacher/statistics", "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token_teacher}}" }] },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('status 200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "UC-TC-01 Teacher Dashboard Stats",
          "request": { "method": "GET", "url": "{{base_url}}/api/teacher/dashboard/stats", "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token_teacher}}" }] },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('status 200', () => pm.response.to.have.status(200));"] } }]
        }
      ]
    },
