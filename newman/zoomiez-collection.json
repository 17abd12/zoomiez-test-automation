{
  "info": {
    "_postman_id": "zoomiez-api-v1",
    "name": "Zoomiez API — Contract Tests (127 use cases)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "{{base_url}}" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "UC-AUTH-01 Register Student",
          "request": { "method": "POST", "url": "{{base_url}}/auth/register/student", "body": { "mode": "raw", "raw": "{\"email\":\"newtest@example.com\",\"password\":\"SecurePass123\",\"name\":\"Test User\",\"class_level\":\"O-Level\",\"school\":\"Test School\"}", "options": { "raw": { "language": "json" } } }, "header": [{ "key": "Content-Type", "value": "application/json" }] },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('status 201 or 400', () => { pm.expect([201, 400]).to.include(pm.response.code); });"] } }]
        },
        {
          "name": "UC-AUTH-01 Register Duplicate Email",
          "request": { "method": "POST", "url": "{{base_url}}/auth/register/student", "body": { "mode": "raw", "raw": "{\"email\":\"{{student_email}}\",\"password\":\"Pass123\",\"name\":\"Dup\"}", "options": { "raw": { "language": "json" } } }, "header": [{ "key": "Content-Type", "value": "application/json" }] },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('status 400', () => pm.response.to.have.status(400));"] } }]
        },
        {
          "name": "UC-AUTH-02 Verify Email — Wrong OTP",
          "request": { "method": "POST", "url": "{{base_url}}/auth/verify-email", "body": { "mode": "raw", "raw": "{\"email\":\"{{student_email}}\",\"otp\":\"000000\"}", "options": { "raw": { "language": "json" } } }, "header": [{ "key": "Content-Type", "value": "application/json" }] },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('status 400 or 404', () => { pm.expect([400, 404]).to.include(pm.response.code); });"] } }]
        },
        {
          "name": "UC-AUTH-03 Login Student",
          "request": { "method": "POST", "url": "{{base_url}}/auth/login", "body": { "mode": "raw", "raw": "{\"email\":\"{{student_email}}\",\"password\":\"{{student_password}}\"}", "options": { "raw": { "language": "json" } } }, "header": [{ "key": "Content-Type", "value": "application/json" }] },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('status 200 or 401', () => { pm.expect([200, 401]).to.include(pm.response.code); }); if(pm.response.code === 200) { const body = pm.response.json(); pm.test('has token', () => pm.expect(body).to.have.property('token')); pm.environment.set('jwt_token_student', body.token); }"] } }]
        },
        {
          "name": "UC-AUTH-03 Login Teacher",
          "request": { "method": "POST", "url": "{{base_url}}/auth/login", "body": { "mode": "raw", "raw": "{\"email\":\"{{teacher_email}}\",\"password\":\"{{teacher_password}}\"}", "options": { "raw": { "language": "json" } } }, "header": [{ "key": "Content-Type", "value": "application/json" }] },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('status 200 or 401', () => { pm.expect([200, 401]).to.include(pm.response.code); }); if(pm.response.code === 200) { pm.environment.set('jwt_token_teacher', pm.response.json().token); }"] } }]
        },
        {
          "name": "UC-AUTH-03 Login Wrong Password",
          "request": { "method": "POST", "url": "{{base_url}}/auth/login", "body": { "mode": "raw", "raw": "{\"email\":\"{{student_email}}\",\"password\":\"WRONGPASS\"}", "options": { "raw": { "language": "json" } } }, "header": [{ "key": "Content-Type", "value": "application/json" }] },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('status 401', () => pm.response.to.have.status(401));"] } }]
        },
        {
          "name": "UC-AUTH-04 Forgot Password — Unknown Email",
          "request": { "method": "POST", "url": "{{base_url}}/auth/forgot-password", "body": { "mode": "raw", "raw": "{\"email\":\"nobody@example.com\"}", "options": { "raw": { "language": "json" } } }, "header": [{ "key": "Content-Type", "value": "application/json" }] },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('no 404 enum', () => pm.expect(pm.response.code).to.not.equal(404));"] } }]
        },
        {
          "name": "UC-AUTH-04 Reset Password — Wrong OTP",
          "request": { "method": "POST", "url": "{{base_url}}/auth/reset-password", "body": { "mode": "raw", "raw": "{\"email\":\"{{student_email}}\",\"otp\":\"000000\",\"new_password\":\"NewPass123\"}", "options": { "raw": { "language": "json" } } }, "header": [{ "key": "Content-Type", "value": "application/json" }] },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('status 400 or 404', () => { pm.expect([400, 404]).to.include(pm.response.code); });"] } }]
        }
      ]
    },
    {
      "name": "2. Papers",
      "item": [
        {
          "name": "UC-SE-03 Available Papers",
          "request": { "method": "GET", "url": "{{base_url}}/papers/available?subject=Chemistry&type=mcq", "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token_student}}" }] },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('status 200 or 404', () => { pm.expect([200, 404]).to.include(pm.response.code); }); if(pm.response.code === 200) { pm.test('returns array', () => pm.expect(pm.response.json()).to.have.property('papers')); }"] } }]
        },
        {
          "name": "UC-SE-04 Random MCQ Paper",
          "request": { "method": "GET", "url": "{{base_url}}/api/papers/random?paper_type=mcq&subject=Chemistry&level=O-Level", "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token_student}}" }] },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('status 200 or 404', () => { pm.expect([200, 404]).to.include(pm.response.code); }); if(pm.response.code === 200){ pm.test('has questions', () => pm.expect(pm.response.json()).to.have.property('questions')); }"] } }]
        },
        {
          "name": "UC-SE-04 Submit MCQ Paper",
          "request": { "method": "POST", "url": "{{base_url}}/api/papers/submit", "body": { "mode": "raw", "raw": "{\"paper_type\":\"mcq\",\"subject\":\"Chemistry\",\"level\":\"O-Level\",\"answers\":{\"1\":\"B\",\"2\":\"C\"},\"paper_ref\":\"test-ref\",\"time_taken_seconds\":120}", "options": { "raw": { "language": "json" } } }, "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token_student}}" }, { "key": "Content-Type", "value": "application/json" }] },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('status 200 or 201', () => { pm.expect([200,201]).to.include(pm.response.code); }); if([200,201].includes(pm.response.code)){ const b = pm.response.json(); pm.environment.set('test_submission_id', b.submission_id || ''); }"] } }]
        },
        {
          "name": "UC-SE-04 Papers — Unauthenticated denied",
          "request": { "method": "GET", "url": "{{base_url}}/api/papers/random" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('status 401 or 403', () => { pm.expect([401, 403, 422]).to.include(pm.response.code); });"] } }]
        },
        {
          "name": "UC-SE-04 Get User Submissions",
          "request": { "method": "GET", "url": "{{base_url}}/api/papers/submissions/{{student_email}}", "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token_student}}" }] },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('status 200 or 404', () => { pm.expect([200,404]).to.include(pm.response.code); });"] } }]
        }
      ]
    },
    {
