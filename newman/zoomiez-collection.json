        },
        {
          "name": "UC-TC-04 Student Cannot Save Quiz",
          "request": { "method": "POST", "url": "{{base_url}}/api/teacher-quiz/save", "body": { "mode": "raw", "raw": "{\"title\":\"Hack Quiz\"}", "options": { "raw": { "language": "json" } } }, "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token_student}}" }, { "key": "Content-Type", "value": "application/json" }] },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('status 403', () => pm.response.to.have.status(403));"] } }]
        },
        {
          "name": "UC-TE-02 Student Available Quizzes",
          "request": { "method": "GET", "url": "{{base_url}}/api/student-quiz/available", "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token_student}}" }] },
