        {
          "name": "UC-TE-03 Student Results",
          "request": { "method": "GET", "url": "{{base_url}}/api/student-quiz/results", "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token_student}}" }] },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('status 200', () => pm.response.to.have.status(200));"] } }]
        }
